#!/bin/bash

LOG_FILE="${TRIM_PKGVAR}/info.log"
PID_FILE="${TRIM_PKGVAR}/app.pid"
PROXY_PID_FILE="${TRIM_PKGVAR}/proxy.pid"

DATA_DIR="${wizard_data_dir:-${TRIM_DATA_SHARE_PATHS%%:*}}"
[ -z "$DATA_DIR" ] && DATA_DIR="${TRIM_PKGVAR}"

APP_PYTHON="${TRIM_APPDEST}/Python/bin/python3"
APP_BACKEND="${TRIM_APPDEST}/后端"
APP_PORT="${wizard_port:-8700}"
APP_INTERNAL_PORT=8700

log_msg() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> ${LOG_FILE}
}

check_process() {
    local pid=$1
    kill -0 "${pid}" 2>/dev/null
}

wait_for_port() {
    local port=$1
    local timeout=$2
    local count=0
    while [ $count -lt $timeout ]; do
        if command -v nc >/dev/null 2>&1; then
            nc -z 127.0.0.1 $port 2>/dev/null && return 0
        elif [ -e /proc/net/tcp ]; then
            python3 -c "import socket; s=socket.socket(); s.settimeout(1); s.connect(('127.0.0.1',$port)); s.close()" 2>/dev/null && return 0
        fi
        sleep 1
        count=$((count + 1))
    done
    return 1
}

start_process() {
    if status; then
        return 0
    fi

    log_msg "启动车辆管理系统 (port=${APP_PORT}, data=${DATA_DIR}) ..."

    mkdir -p "${DATA_DIR}/db" "${DATA_DIR}/photos"

    cd "${APP_BACKEND}" || {
        log_msg "无法进入后端目录: ${APP_BACKEND}"
        return 1
    }

    # 设置环境变量
    export DATA_DIR="${DATA_DIR}"
    export DB_DIR="${DATA_DIR}/db"
    export UPLOAD_DIR="${DATA_DIR}/photos"
    export SECRET_KEY="vehicle-mgr-fnas-$(date +%s)-${TRIM_PKGVAR}"

    # 启动 uvicorn
    nohup "${APP_PYTHON}" -m uvicorn main:app --host 0.0.0.0 --port ${APP_INTERNAL_PORT} --workers 1 >> ${LOG_FILE} 2>&1 &
    printf "%s" "$!" > ${PID_FILE}

    if wait_for_port $APP_INTERNAL_PORT 30; then
        log_msg "服务已启动 (PID: $(cat ${PID_FILE}))"
    else
        log_msg "服务启动超时，请检查日志"
    fi

    return 0
}

stop_process() {
    log_msg "停止车辆管理系统 ..."

    if [ -r "${PID_FILE}" ]; then
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
        log_msg "主进程 pid=${pid}"
        if ! check_process ${pid}; then
            log_msg "主进程未运行"
            rm -f ${PID_FILE}
            return 0
        fi
        kill -TERM ${pid} 2>/dev/null
        local i=0
        while [ $i -lt 10 ]; do
            if ! check_process ${pid}; then
                log_msg "主进程已停止"
                rm -f ${PID_FILE}
                return 0
            fi
            sleep 1
            i=$((i + 1))
        done
        kill -KILL ${pid} 2>/dev/null
        log_msg "强制终止主进程"
        rm -f ${PID_FILE}
    fi
    return 0
}

is_process_alive() {
    [ -r "${PID_FILE}" ] || return 1
    pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
    check_process ${pid}
}

status() {
    if is_process_alive; then
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
        echo "running: pid=${pid}"
        return 0
    else
        echo "stopped"
        rm -f ${PID_FILE}
        return 3
    fi
}

case "$1" in
    start)
        start_process
        ;;
    stop)
        stop_process
        ;;
    status)
        status
        ;;
    restart)
        stop_process
        sleep 1
        start_process
        ;;
    *)
        echo "Usage: $0 {start|stop|status|restart}"
        exit 1
        ;;
esac
